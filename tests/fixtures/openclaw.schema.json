{
  "type": "object",
  "required": ["provider"],
  "properties": {
    "provider": {
      "type": "string",
      "enum": ["anthropic", "openai", "groq", "openrouter"]
    },
    "model": {
      "type": "string"
    },
    "tools": {
      "type": "object",
      "properties": {
        "elevated": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false }
          }
        }
      }
    },
    "channels": {
      "type": "object",
      "properties": {
        "telegram": {
          "type": "object",
          "properties": {
            "botToken": { "type": "string" }
          }
        }
      }
    }
  }
}
